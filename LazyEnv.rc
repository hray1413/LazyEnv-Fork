// ============================================================================
// LazyEnv - LazyEnv.rc
// Windows resource script: icon and version information
// ============================================================================

#include <winver.h>

// --- Application Icon ---
IDI_APPICON ICON "resources\\lazyenv.ico"

// --- Version Information ---
VS_VERSION_INFO VERSIONINFO
    FILEVERSION    0,1,0,0
    PRODUCTVERSION 0,1,0,0
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
    FILEFLAGS      0x0L
    FILEOS         VOS_NT_WINDOWS32
    FILETYPE       VFT_APP
    FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "LazyEnv Project"
            VALUE "FileDescription",  "LazyEnv - Development Environment Setup Tool"
            VALUE "FileVersion",      "0.1.0"
            VALUE "InternalName",     "LazyEnv"
            VALUE "LegalCopyright",   "MIT License"
            VALUE "OriginalFilename", "LazyEnv.exe"
            VALUE "ProductName",      "LazyEnv"
            VALUE "ProductVersion",   "0.1.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
